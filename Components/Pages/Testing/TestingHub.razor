@page "/testing"
@inject QubicBackendService Backend

<h4><i class="bi bi-bug me-2"></i>Testing</h4>
<p class="text-muted">Development, testnet, and stress testing tools.</p>

<div class="row g-3">
    <div class="col-md-6 col-lg-4">
        <a href="/testing/sc-tester" class="text-decoration-none">
            <div class="card h-100 hub-card">
                <div class="card-body d-flex align-items-start gap-3">
                    <i class="bi bi-file-code fs-2 text-primary"></i>
                    <div>
                        <h5 class="card-title mb-1">SC Tester</h5>
                        <p class="card-text text-muted small mb-0">Parse C++ contract headers and dynamically call functions and procedures</p>
                    </div>
                </div>
            </div>
        </a>
    </div>
    @if (IsDirectNetwork)
    {
        <div class="col-md-6 col-lg-4">
            <a href="/testing/arbitrator" class="text-decoration-none">
                <div class="card h-100 hub-card">
                    <div class="card-body d-flex align-items-start gap-3">
                        <i class="bi bi-shield-lock fs-2 text-primary"></i>
                        <div>
                            <h5 class="card-title mb-1">Arbitrator Tools</h5>
                            <p class="card-text text-muted small mb-0">Testnet arbitrator operations: broadcast computor lists, manage epoch lifecycle</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="/testing/stress-test" class="text-decoration-none">
                <div class="card h-100 hub-card">
                    <div class="card-body d-flex align-items-start gap-3">
                        <i class="bi bi-lightning-charge fs-2 text-primary"></i>
                        <div>
                            <h5 class="card-title mb-1">Stress Test</h5>
                            <p class="card-text text-muted small mb-0">Network stress testing: transaction flooding, message injection, load testing</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@code {
    private bool IsDirectNetwork => Backend.ActiveBackend == QueryBackend.DirectNetwork;
}
