    // ── Step editor helpers ──

    private PlaybookStep CaptureFieldsToStep()
    {
        return new PlaybookStep
        {
            Label = _editStep.Label,
            Type = _testType,
            Count = _totalCount,
            Concurrency = _concurrency,
            DelayMs = _delayMs,
            TxSeeds = _testType == TestType.TransactionFlood && !string.IsNullOrWhiteSpace(_txSeeds) ? _txSeeds : null,
            TxDestination = _testType == TestType.TransactionFlood ? _txDestination : null,
            TxAmount = _testType == TestType.TransactionFlood ? _txAmount : null,
            TxTickOffset = _testType == TestType.TransactionFlood ? _txTickOffset : null,
            TxPerSeedPerTick = _testType == TestType.TransactionFlood ? _txPerSeedPerTick : null,
            TxSameTick = _testType == TestType.TransactionFlood ? _txSameTick : null,
            ScContractIndex = _testType == TestType.ScQueryFlood ? _scContractIndex : null,
            ScInputType = _testType == TestType.ScQueryFlood ? _scInputType : null,
            ScInputHex = _testType == TestType.ScQueryFlood && !string.IsNullOrWhiteSpace(_scInputHex) ? _scInputHex : null,
            MsgType = _testType == TestType.MessageFlood ? _msgType : null,
            MsgPayloadHex = _testType == TestType.MessageFlood && !string.IsNullOrWhiteSpace(_msgPayloadHex) ? _msgPayloadHex : null,
            RawType = _testType == TestType.RawPacket ? _rawType : null,
            RawHex = _testType == TestType.RawPacket && !string.IsNullOrWhiteSpace(_rawHex) ? _rawHex : null,
        };
    }

    private void LoadStepIntoFields(PlaybookStep step)
    {
        _testType = step.Type;
        _totalCount = step.Count;
        _concurrency = step.Concurrency;
        _delayMs = step.DelayMs;
        _txSeeds = step.TxSeeds ?? "";
        _txDestination = step.TxDestination ?? "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA";
        _txAmount = step.TxAmount ?? 0;
        _txTickOffset = step.TxTickOffset ?? 10;
        _txPerSeedPerTick = step.TxPerSeedPerTick ?? 1;
        _txSameTick = step.TxSameTick ?? true;
        _scContractIndex = step.ScContractIndex ?? 4;
        _scInputType = step.ScInputType ?? 1;
        _scInputHex = step.ScInputHex ?? "";
        _msgType = step.MsgType ?? QubicPacketTypes.RequestCurrentTickInfo;
        _msgPayloadHex = step.MsgPayloadHex ?? "";
        _rawType = step.RawType ?? 0;
        _rawHex = step.RawHex ?? "";
    }

    private void AddNewStep()
    {
        _editStep = new PlaybookStep { Type = _testType };
        _editingStepIndex = -1;
        _showStepEditor = true;
    }

    private void EditStep(int index)
    {
        var step = _playbook.Steps[index];
        _editStep = JsonSerializer.Deserialize<PlaybookStep>(JsonSerializer.Serialize(step, JsonOpts), JsonOpts)!;
        LoadStepIntoFields(_editStep);
        _editingStepIndex = index;
        _showStepEditor = true;
    }

    private void SaveStep()
    {
        var step = CaptureFieldsToStep();
        if (_editingStepIndex >= 0 && _editingStepIndex < _playbook.Steps.Count)
            _playbook.Steps[_editingStepIndex] = step;
        else
            _playbook.Steps.Add(step);
        _showStepEditor = false;
        _editingStepIndex = -1;
    }

    private void CancelStepEdit()
    {
        _showStepEditor = false;
        _editingStepIndex = -1;
    }

    private void RemoveStep(int index) => _playbook.Steps.RemoveAt(index);

    private void MoveStepUp(int index)
    {
        if (index <= 0) return;
        (_playbook.Steps[index - 1], _playbook.Steps[index]) = (_playbook.Steps[index], _playbook.Steps[index - 1]);
    }

    private void MoveStepDown(int index)
    {
        if (index >= _playbook.Steps.Count - 1) return;
        (_playbook.Steps[index], _playbook.Steps[index + 1]) = (_playbook.Steps[index + 1], _playbook.Steps[index]);
    }

    private void ClearPlaybook()
    {
        _playbook = new StressPlaybook();
        _stepResults.Clear();
        _errorLog.Clear();
        _showStepEditor = false;
        _playbookMessage = null;
    }

    private void ClearResults()
    {
        _stepResults.Clear();
        _errorLog.Clear();
    }

    // ── Save / Load ──

    private async Task SavePlaybook()
    {
        try
        {
            var json = JsonSerializer.Serialize(_playbook, JsonOpts);
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(bytes);
            var safeName = string.Join("_", _playbook.Name.Split(Path.GetInvalidFileNameChars()));
            var filename = $"playbook-{safeName}-{DateTime.Now:yyyyMMdd-HHmmss}.json";
            await JS.InvokeVoidAsync("downloadFile", filename, "application/json", base64);
            _playbookMessage = $"Saved \"{_playbook.Name}\" ({_playbook.Steps.Count} steps).";
            _playbookMsgSuccess = true;
        }
        catch (Exception ex)
        {
            _playbookMessage = "Save failed: " + ex.Message;
            _playbookMsgSuccess = false;
        }
    }

    private async Task LoadPlaybook()
    {
        _playbookMessage = null;
        try
        {
            var content = await JS.InvokeAsync<string?>("readFileAsText", "playbookFileInput");
            if (content == null) return;
            var loaded = JsonSerializer.Deserialize<StressPlaybook>(content, JsonOpts);
            if (loaded == null)
            {
                _playbookMessage = "Invalid playbook file.";
                _playbookMsgSuccess = false;
                return;
            }
            _playbook = loaded;
            _stepResults.Clear();
            _errorLog.Clear();
            _showStepEditor = false;
            _playbookMessage = $"Loaded \"{_playbook.Name}\" with {_playbook.Steps.Count} step(s).";
            _playbookMsgSuccess = true;
        }
        catch (JsonException ex)
        {
            _playbookMessage = "Invalid JSON: " + ex.Message;
            _playbookMsgSuccess = false;
        }
        catch (Exception ex)
        {
            _playbookMessage = "Load failed: " + ex.Message;
            _playbookMsgSuccess = false;
        }
    }

    // ── Execution ──

    private async Task StartQuickTest()
    {
        _stats = new TestStats();
        _errorLog.Clear();
        _running = true;
        _cts = new CancellationTokenSource();
        _uiTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 250, 250);

        // For TX flood, build work items and set total count from seeds × perSeed
        if (_testType == TestType.TransactionFlood)
        {
            _txWorkItems = BuildTxWorkItems();
            _totalCount = _txWorkItems.Length;
        }

        try
        {
            await RunStepIterations(_totalCount, _concurrency, _delayMs, _cts.Token);
        }
        catch (OperationCanceledException) { }
        finally
        {
            _running = false;
            _txWorkItems = null;
            _uiTimer?.Dispose();
            _uiTimer = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunPlaybook()
    {
        _stepResults.Clear();
        _errorLog.Clear();
        _running = true;
        _cts = new CancellationTokenSource();
        _uiTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, 250, 250);
        try
        {
            for (int i = 0; i < _playbook.Steps.Count; i++)
            {
                if (_cts.Token.IsCancellationRequested) break;
                var step = _playbook.Steps[i];
                _currentStepIndex = i;
                _stats = new TestStats();
                LoadStepIntoFields(step);

                var count = step.Count;
                if (step.Type == TestType.TransactionFlood)
                {
                    _txWorkItems = BuildTxWorkItems();
                    count = _txWorkItems.Length;
                }

                await InvokeAsync(StateHasChanged);
                await RunStepIterations(count, step.Concurrency, step.DelayMs, _cts.Token);
                _txWorkItems = null;
                _stepResults.Add(new TestStats
                {
                    Sent = _stats.Sent, Success = _stats.Success, Failed = _stats.Failed,
                    Elapsed = _stats.Elapsed, TotalResponseMs = _stats.TotalResponseMs,
                });
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _currentStepIndex = -1;
            _running = false;
            _uiTimer?.Dispose();
            _uiTimer = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunStepIterations(int count, int concurrency, int delayMs, CancellationToken ct)
    {
        var sw = Stopwatch.StartNew();
        var semaphore = new SemaphoreSlim(concurrency);
        var tasks = new List<Task>();
        for (int i = 0; i < count; i++)
        {
            if (ct.IsCancellationRequested) break;
            await semaphore.WaitAsync(ct);
            var index = i;
            tasks.Add(Task.Run(async () =>
            {
                try
                {
                    var opSw = Stopwatch.StartNew();
                    await ExecuteOne(index, ct);
                    opSw.Stop();
                    Interlocked.Add(ref _stats.TotalResponseMs, opSw.ElapsedMilliseconds);
                    Interlocked.Increment(ref _stats.Success);
                }
                catch (OperationCanceledException) { }
                catch (Exception ex)
                {
                    Interlocked.Increment(ref _stats.Failed);
                    lock (_errorLog) { if (_errorLog.Count < 500) _errorLog.Add((index, ex.Message.Length > 120 ? ex.Message[..120] + "..." : ex.Message)); }
                }
                finally
                {
                    Interlocked.Increment(ref _stats.Sent);
                    _stats.Elapsed = sw.Elapsed;
                    semaphore.Release();
                }
                if (delayMs > 0) await Task.Delay(delayMs, ct).ConfigureAwait(false);
            }, ct));
        }
        await Task.WhenAll(tasks);
        sw.Stop();
        _stats.Elapsed = sw.Elapsed;
    }

    private async Task ExecuteOne(int index, CancellationToken ct)
    {
        switch (_testType)
        {
            case TestType.TransactionFlood: await ExecuteTxFlood(index, ct); break;
            case TestType.ScQueryFlood: await ExecuteScQuery(ct); break;
            case TestType.MessageFlood: await ExecuteMessageFlood(ct); break;
            case TestType.RawPacket: await ExecuteRawPacket(ct); break;
        }
    }

    private async Task ExecuteTxFlood(int index, CancellationToken ct)
    {
        if (_txWorkItems == null || _txWorkItems.Length == 0) return;
        var (seed, source) = _txWorkItems[index % _txWorkItems.Length];
        var dest = QubicIdentity.FromIdentity(_txDestination.Trim());
        var tick = _txSameTick
            ? (uint)(TickMonitor.Tick + _txTickOffset)
            : (uint)(TickMonitor.Tick + _txTickOffset + index);
        var builder = new TransactionBuilder();
        var tx = builder.CreateTransfer(source, dest, _txAmount, tick);
        builder.Sign(tx, seed);
        await Backend.BroadcastTransactionAsync(tx, ct);
    }

    private static string[] ParseSeedLines(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return [];
        return text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                   .Where(s => s.Length == 55)
                   .ToArray();
    }

    private (string Seed, QubicIdentity Source)[] BuildTxWorkItems()
    {
        var seeds = ParseSeedLines(_txSeeds);
        if (seeds.Length == 0) return [];

        // Build work items: each seed × txPerSeedPerTick, then shuffle
        var items = new List<(string Seed, QubicIdentity Source)>();
        foreach (var seed in seeds)
        {
            var identity = QubicIdentity.FromSeed(seed);
            for (int j = 0; j < _txPerSeedPerTick; j++)
                items.Add((seed, identity));
        }

        // Fisher-Yates shuffle for random distribution
        var rng = Random.Shared;
        for (int i = items.Count - 1; i > 0; i--)
        {
            int k = rng.Next(i + 1);
            (items[i], items[k]) = (items[k], items[i]);
        }

        return items.ToArray();
    }

    private async Task ExecuteScQuery(CancellationToken ct)
    {
        var input = string.IsNullOrWhiteSpace(_scInputHex) ? Array.Empty<byte>() : Convert.FromHexString(_scInputHex.Trim());
        await Backend.QuerySmartContractAsync(_scContractIndex, _scInputType, input, ct);
    }

    private async Task ExecuteMessageFlood(CancellationToken ct)
    {
        var payload = string.IsNullOrWhiteSpace(_msgPayloadHex) ? Array.Empty<byte>() : Convert.FromHexString(_msgPayloadHex.Trim());
        await Backend.SendRawPacketAsync(BuildPacket((byte)_msgType, payload), ct);
    }

    private async Task ExecuteRawPacket(CancellationToken ct)
    {
        var payload = string.IsNullOrWhiteSpace(_rawHex) ? Array.Empty<byte>() : Convert.FromHexString(_rawHex.Trim());
        await Backend.SendRawPacketAsync(BuildPacket((byte)_rawType, payload), ct);
    }

    private static byte[] BuildPacket(byte type, byte[] payload)
    {
        var header = QubicPacketHeader.Create(type, payload.Length, dejavu: 0);
        var packet = new byte[QubicPacketHeader.Size + payload.Length];
        uint sizeAndType = (uint)header.PacketSize | ((uint)header.Type << 24);
        BinaryPrimitives.WriteUInt32LittleEndian(packet.AsSpan(0), sizeAndType);
        BinaryPrimitives.WriteUInt32LittleEndian(packet.AsSpan(4), header.Dejavu);
        if (payload.Length > 0) payload.CopyTo(packet.AsSpan(QubicPacketHeader.Size));
        return packet;
    }

    private void StopTest() => _cts?.Cancel();

    private void ResetStats() { _stats = new TestStats(); _errorLog.Clear(); }

    // ── Formatting ──

    private static string FormatElapsed(TimeSpan ts) =>
        ts.TotalMinutes >= 1 ? $"{ts.Minutes}m {ts.Seconds}s" : $"{ts.TotalSeconds:F1}s";

    private static string FormatStatsRate(TestStats s) =>
        s.Elapsed.TotalSeconds < 0.01 ? "0" : (s.Sent / s.Elapsed.TotalSeconds).ToString("F1");

    private static string FormatAvgResponse(TestStats s)
    {
        var count = s.Success + s.Failed;
        return count == 0 ? "-" : $"{s.TotalResponseMs / count}ms";
    }

    private static string FormatTestType(TestType t) => t switch
    {
        TestType.TransactionFlood => "TX Flood",
        TestType.ScQueryFlood => "SC Query",
        TestType.MessageFlood => "Msg Flood",
        TestType.RawPacket => "Raw Pkt",
        _ => t.ToString()
    };

    private static string FormatStepSummary(PlaybookStep s)
    {
        var parts = new List<string> { $"{s.Count}\u00d7 @ {s.Concurrency} concurrent" };
        switch (s.Type)
        {
            case TestType.TransactionFlood:
                var sc = ParseSeedLines(s.TxSeeds ?? "").Length;
                parts.Clear();
                parts.Add($"{sc} seeds \u00d7 {s.TxPerSeedPerTick ?? 1}");
                parts.Add(s.TxSameTick == true ? "same tick" : "unique ticks");
                if (s.TxAmount > 0) parts.Add($"{s.TxAmount} QU");
                break;
            case TestType.ScQueryFlood: parts.Insert(0, $"Contract {s.ScContractIndex}, Type {s.ScInputType}"); break;
            case TestType.MessageFlood: parts.Insert(0, $"MsgType {s.MsgType}"); break;
            case TestType.RawPacket: parts.Insert(0, $"PktType {s.RawType}"); break;
        }
        if (s.DelayMs > 0) parts.Add($"{s.DelayMs}ms delay");
        return string.Join(" \u2014 ", parts);
    }

    private TestStats AggregateTotals()
    {
        var t = new TestStats();
        foreach (var sr in _stepResults)
        {
            t.Sent += sr.Sent; t.Success += sr.Success; t.Failed += sr.Failed;
            t.Elapsed += sr.Elapsed; t.TotalResponseMs += sr.TotalResponseMs;
        }
        return t;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _uiTimer?.Dispose();
    }
}
