@page "/testing/stress-test"
@using System.Buffers.Binary
@using System.Diagnostics
@using System.Text.Json
@using System.Text.Json.Serialization
@using Qubic.Core
@using Qubic.Core.Entities
@using Qubic.Serialization
@inject QubicBackendService Backend
@inject SeedSessionService SeedSession
@inject TickMonitorService TickMonitor
@inject IJSRuntime JS
@implements IDisposable

<h4><i class="bi bi-lightning-charge me-2"></i>Stress Test</h4>
<p class="text-muted">Network stress testing and load generation. DirectNetwork only.</p>

@if (Backend.ActiveBackend != QueryBackend.DirectNetwork)
{
    <div class="alert alert-warning">This tool requires DirectNetwork backend. Switch in Settings.</div>
    return;
}

@* ── MODE TABS ── *@
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_mode == "quick" ? "active" : "")" @onclick='() => _mode = "quick"' disabled="@_running">
            <i class="bi bi-lightning-charge me-1"></i>Quick Test
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_mode == "playbook" ? "active" : "")" @onclick='() => _mode = "playbook"' disabled="@_running">
            <i class="bi bi-journal-code me-1"></i>Playbook
        </button>
    </li>
</ul>

@* ════════════════════════════════════════════════════════════════════ *@
@* ── QUICK TEST MODE ── *@
@* ════════════════════════════════════════════════════════════════════ *@
@if (_mode == "quick")
{
    <div class="card mb-3">
        <div class="card-header">Test Configuration</div>
        <div class="card-body">
            @ConfigPanel

            <div class="d-flex gap-2 mt-2">
                @if (!_running)
                {
                    <button class="btn btn-danger" @onclick="StartQuickTest"
                            disabled="@(_testType == TestType.TransactionFlood && ParseSeedLines(_txSeeds).Length == 0)">
                        <i class="bi bi-lightning-charge me-1"></i>Start Test
                    </button>
                }
                else
                {
                    <button class="btn btn-warning" @onclick="StopTest">
                        <i class="bi bi-stop-fill me-1"></i>Stop
                    </button>
                }
                @if (!_running && _stats.Sent > 0)
                {
                    <button class="btn btn-outline-secondary" @onclick="ResetStats">Reset Stats</button>
                }
            </div>
        </div>
    </div>

    @* Quick test live stats *@
    if (_stats.Sent > 0 || _running)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                Live Stats
                @if (_running) { <span class="badge bg-danger">Running</span> }
                else { <span class="badge bg-secondary">Stopped</span> }
            </div>
            <div class="card-body">
                <div class="row g-2 text-center">
                    <div class="col"><div class="small text-muted">Sent</div><div class="h5 mono mb-0">@_stats.Sent</div></div>
                    <div class="col"><div class="small text-muted">Success</div><div class="h5 mono mb-0 text-success">@_stats.Success</div></div>
                    <div class="col"><div class="small text-muted">Failed</div><div class="h5 mono mb-0 text-danger">@_stats.Failed</div></div>
                    <div class="col"><div class="small text-muted">Elapsed</div><div class="h5 mono mb-0">@FormatElapsed(_stats.Elapsed)</div></div>
                    <div class="col"><div class="small text-muted">Rate</div><div class="h5 mono mb-0">@FormatStatsRate(_stats) /s</div></div>
                    <div class="col"><div class="small text-muted">Avg Response</div><div class="h5 mono mb-0">@FormatAvgResponse(_stats)</div></div>
                </div>
                @{ var qPct = _totalCount > 0 ? (int)(100.0 * _stats.Sent / _totalCount) : 0; }
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar @(_running ? "bg-danger" : "bg-success")" style="width: @(qPct)%"></div>
                </div>
                <div class="small text-muted text-center mt-1">@_stats.Sent / @_totalCount</div>
            </div>
        </div>
    }

    @* Quick test error log *@
    if (_errorLog.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                Error Log <span class="badge bg-danger">@_errorLog.Count</span>
            </div>
            <div class="card-body p-0">
                <div style="max-height:200px; overflow-y:auto">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead><tr><th style="width:60px">#</th><th>Error</th></tr></thead>
                        <tbody>
                            @foreach (var (eidx, emsg) in _errorLog.TakeLast(50))
                            {
                                <tr><td class="mono">@eidx</td><td class="text-danger">@emsg</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@* ════════════════════════════════════════════════════════════════════ *@
@* ── PLAYBOOK MODE ── *@
@* ════════════════════════════════════════════════════════════════════ *@
@if (_mode == "playbook")
{
    @* ── PLAYBOOK HEADER ── *@
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            Playbook
            <div class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-primary" @onclick="SavePlaybook" disabled="@_running" title="Save to file">
                    <i class="bi bi-download me-1"></i>Save
                </button>
                <button class="btn btn-sm btn-outline-primary" @onclick="LoadPlaybook" disabled="@_running" title="Load from file">
                    <i class="bi bi-upload me-1"></i>Load
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearPlaybook" disabled="@_running" title="Clear all steps">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label small mb-0">Playbook Name</label>
                    <input class="form-control form-control-sm" @bind="_playbook.Name" disabled="@_running" />
                </div>
                <div class="col-md-8">
                    <label class="form-label small mb-0">Description</label>
                    <input class="form-control form-control-sm" @bind="_playbook.Description" disabled="@_running"
                           placeholder="Optional description..." />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_playbookMessage))
            {
                <div class="alert @(_playbookMsgSuccess ? "alert-success" : "alert-danger") py-1 px-2 small mb-0">
                    @_playbookMessage
                </div>
            }
        </div>
    </div>

    @* ── STEPS LIST ── *@
    @if (_playbook.Steps.Count > 0)
    {
        <div class="mb-3">
            @for (int si = 0; si < _playbook.Steps.Count; si++)
            {
                var step = _playbook.Steps[si];
                var idx = si;
                var isCurrentStep = _running && _currentStepIndex == idx;
                var isCompleted = (_running && idx < _currentStepIndex) || (!_running && _stepResults.Count > idx);

                <div class="card mb-2 @(isCurrentStep ? "border-danger" : "")">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                @if (isCurrentStep)
                                {
                                    <span class="badge bg-danger">Running</span>
                                }
                                else if (isCompleted && _stepResults.Count > idx)
                                {
                                    <span class="badge bg-success">Done</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">#@(idx + 1)</span>
                                }
                                <span class="badge bg-info text-dark">@FormatTestType(step.Type)</span>
                                <span class="small fw-bold">@(string.IsNullOrEmpty(step.Label) ? $"Step {idx + 1}" : step.Label)</span>
                                <span class="small text-muted">@FormatStepSummary(step)</span>
                            </div>
                            @if (!_running)
                            {
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="() => MoveStepUp(idx)"
                                            disabled="@(idx == 0)" title="Move up"><i class="bi bi-chevron-up"></i></button>
                                    <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="() => MoveStepDown(idx)"
                                            disabled="@(idx == _playbook.Steps.Count - 1)" title="Move down"><i class="bi bi-chevron-down"></i></button>
                                    <button class="btn btn-sm btn-outline-primary py-0 px-1" @onclick="() => EditStep(idx)"
                                            title="Edit"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemoveStep(idx)"
                                            title="Remove"><i class="bi bi-trash"></i></button>
                                </div>
                            }
                        </div>
                        @if (isCurrentStep && (_stats.Sent > 0 || _running))
                        {
                            <div class="row g-2 text-center mt-2 small">
                                <div class="col">Sent: <span class="mono">@_stats.Sent</span></div>
                                <div class="col">Success: <span class="mono text-success">@_stats.Success</span></div>
                                <div class="col">Failed: <span class="mono text-danger">@_stats.Failed</span></div>
                                <div class="col">Rate: <span class="mono">@FormatStatsRate(_stats) /s</span></div>
                                <div class="col">Elapsed: <span class="mono">@FormatElapsed(_stats.Elapsed)</span></div>
                            </div>
                            <div class="progress mt-1" style="height: 4px;">
                                <div class="progress-bar bg-danger" style="width: @(step.Count > 0 ? (int)(100.0 * _stats.Sent / step.Count) : 0)%"></div>
                            </div>
                        }
                        else if (_stepResults.Count > idx)
                        {
                            var sr = _stepResults[idx];
                            <div class="small text-muted mt-1">
                                Sent @sr.Sent | Success @sr.Success | Failed @sr.Failed |
                                @FormatElapsed(sr.Elapsed) | @FormatStatsRate(sr) /s
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (!_showStepEditor)
    {
        <div class="text-muted small mb-3">No steps defined. Add a step to build your playbook.</div>
    }

    @* ── STEP EDITOR ── *@
    @if (_showStepEditor && !_running)
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                <span>@(_editingStepIndex >= 0 ? $"Edit Step #{_editingStepIndex + 1}" : "Add Step")</span>
                <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="CancelStepEdit">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="card-body">
                <div class="row g-2 mb-2">
                    <div class="col-md-4">
                        <label class="form-label small mb-0">Step Label</label>
                        <input class="form-control form-control-sm" @bind="_editStep.Label" placeholder="Optional name..." />
                    </div>
                </div>

                @ConfigPanel

                <button class="btn btn-sm btn-primary mt-2" @onclick="SaveStep">
                    <i class="bi bi-check-lg me-1"></i>@(_editingStepIndex >= 0 ? "Update Step" : "Add Step")
                </button>
            </div>
        </div>
    }

    @* ── ADD / RUN CONTROLS ── *@
    <div class="d-flex gap-2 mb-3">
        @if (!_running)
        {
            if (!_showStepEditor)
            {
                <button class="btn btn-outline-primary" @onclick="AddNewStep">
                    <i class="bi bi-plus-lg me-1"></i>Add Step
                </button>
            }
            if (_playbook.Steps.Count > 0)
            {
                <button class="btn btn-danger" @onclick="RunPlaybook" disabled="@(_showStepEditor)">
                    <i class="bi bi-play-fill me-1"></i>Run Playbook (@_playbook.Steps.Count steps)
                </button>
            }
            if (_stepResults.Count > 0)
            {
                <button class="btn btn-outline-secondary" @onclick="ClearResults">Clear Results</button>
            }
        }
        else
        {
            <button class="btn btn-warning" @onclick="StopTest">
                <i class="bi bi-stop-fill me-1"></i>Stop Playbook
            </button>
            <span class="align-self-center small text-muted">
                Step @(_currentStepIndex + 1) / @_playbook.Steps.Count
            </span>
        }
    </div>

    @* ── PLAYBOOK SUMMARY TABLE ── *@
    @if (!_running && _stepResults.Count > 0)
    {
        var totals = AggregateTotals();
        <div class="card mb-3">
            <div class="card-header">Playbook Results</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0 small">
                    <thead>
                        <tr><th>#</th><th>Label</th><th>Type</th><th class="text-end">Sent</th><th class="text-end">Success</th><th class="text-end">Failed</th><th class="text-end">Rate</th><th class="text-end">Elapsed</th></tr>
                    </thead>
                    <tbody>
                        @for (int ri = 0; ri < _stepResults.Count; ri++)
                        {
                            var sr = _stepResults[ri];
                            var stp = ri < _playbook.Steps.Count ? _playbook.Steps[ri] : null;
                            <tr>
                                <td>@(ri + 1)</td>
                                <td>@(stp != null && !string.IsNullOrEmpty(stp.Label) ? stp.Label : $"Step {ri + 1}")</td>
                                <td><span class="badge bg-info text-dark">@(stp != null ? FormatTestType(stp.Type) : "?")</span></td>
                                <td class="text-end mono">@sr.Sent</td>
                                <td class="text-end mono text-success">@sr.Success</td>
                                <td class="text-end mono text-danger">@sr.Failed</td>
                                <td class="text-end mono">@FormatStatsRate(sr) /s</td>
                                <td class="text-end mono">@FormatElapsed(sr.Elapsed)</td>
                            </tr>
                        }
                        <tr class="fw-bold table-light">
                            <td colspan="3">Total</td>
                            <td class="text-end mono">@totals.Sent</td>
                            <td class="text-end mono text-success">@totals.Success</td>
                            <td class="text-end mono text-danger">@totals.Failed</td>
                            <td class="text-end mono">@FormatStatsRate(totals) /s</td>
                            <td class="text-end mono">@FormatElapsed(totals.Elapsed)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Playbook error log *@
    if (_errorLog.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                Error Log <span class="badge bg-danger">@_errorLog.Count</span>
            </div>
            <div class="card-body p-0">
                <div style="max-height:200px; overflow-y:auto">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead><tr><th style="width:60px">#</th><th>Error</th></tr></thead>
                        <tbody>
                            @foreach (var (eidx2, emsg2) in _errorLog.TakeLast(50))
                            {
                                <tr><td class="mono">@eidx2</td><td class="text-danger">@emsg2</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

<input type="file" id="playbookFileInput" accept=".json" style="display:none" />

